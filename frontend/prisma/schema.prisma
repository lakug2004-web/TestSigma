// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Better Auth core schema
// https://www.better-auth.com/docs/concepts/database#core-schema
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Cached AST analysis result (RepoTree JSON) per user + repository.
// Lets us serve a previously generated AST instead of re-analyzing.
// ---------------------------------------------------------------------------

model RepoAst {
  id        String   @id @default(cuid())
  userId    String
  fullName  String
  tree      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, fullName])
  @@map("repo_ast")
}

// ---------------------------------------------------------------------------
// Live-app crawl: one run captures N screens (DOM + a11y + screenshot) plus the
// screen-relationship graph (edges). Screenshots live in Supabase Storage; the
// row holds their public URL. DOM/elements/a11y/edges are stored as JSON.
// ---------------------------------------------------------------------------

model CrawlRun {
  id          String        @id @default(cuid())
  userId      String
  fullName    String // GitHub repo this crawl belongs to (owner/repo)
  baseUrl     String
  // The exact route list the user provided: [{ path, authenticated }].
  routes      Json          @default("[]")
  runId       String        @unique // backend run id (artifact namespace)
  screenCount Int           @default(0)
  // The screen-relationship graph: [{ from, to, via }] edges as JSON.
  edges       Json          @default("[]")
  createdAt   DateTime      @default(now())
  screens     CrawlScreen[]

  @@index([userId, fullName])
  @@map("crawl_run")
}

// ---------------------------------------------------------------------------
// Ingested product spec (PRD / README / wiki) parsed into structured
// requirements — the "Requirements" layer of the knowledge graph. One row per
// user + repo + source document; `requirements` is the structured list JSON.
// ---------------------------------------------------------------------------

model RepoRequirements {
  id               String   @id @default(cuid())
  userId           String
  fullName         String // GitHub repo these requirements describe (owner/repo)
  source           String // the doc URL / owner-repo / "text"
  sourceType       String   @default("url") // url | text | github_readme
  requirementCount Int      @default(0)
  // Structured requirements: [{ req_id, title, user_action, expected_outcome, priority, source_anchor }].
  requirements     Json     @default("[]")
  // Repo-relative paths of the doc files ingested (github_repo source).
  files            Json     @default("[]")
  // Deep, whole-codebase description synthesised from all ingested docs.
  overview         String   @default("")
  excerpt          String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, fullName])
  @@index([fullName])
  @@map("repo_requirements")
}

// ---------------------------------------------------------------------------
// One row per pull request seen for a repo: GitHub metadata (always) plus the
// latest blast-radius review (filled once the Reason layer runs). The webhook
// reasoner upserts the review fields; the dashboard upserts the metadata when it
// lists PRs. Unique on (fullName, prNumber) so both writers converge on one row.
// ---------------------------------------------------------------------------

model PrReview {
  id          String    @id @default(cuid())
  userId      String? // set when persisted via the dashboard; null from webhook
  fullName    String // owner/repo
  prNumber    Int
  title       String    @default("")
  author      String    @default("")
  state       String    @default("open") // open | closed | merged
  url         String    @default("")
  headSha     String    @default("")
  baseRef     String    @default("")
  headRef     String    @default("")
  reviewed    Boolean   @default(false)
  verdict     String    @default("") // approve | request_changes | comment
  risk        String    @default("") // low | medium | high
  goodEnough  Boolean   @default(false)
  summary     String    @default("")
  // Full structured blast radius: { changes_made, ui_at_risk, flows_affected,
  // requirements_at_risk, issues_addressed, suggestions }.
  blastRadius Json      @default("{}")
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([fullName, prNumber])
  @@index([fullName])
  @@map("pr_review")
}

model CrawlScreen {
  id              String   @id @default(cuid())
  runId           String
  run             CrawlRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  screenId        String // stable hash from the crawler
  url             String
  title           String   @default("")
  label           String   @default("")
  authenticated   Boolean  @default(false)
  screenshotUrl   String   @default("") // Supabase Storage public URL (or data URI fallback)
  interactiveCount Int     @default(0)
  // Full captured artifacts as JSON: { dom, a11y, elements }.
  artifacts       Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([runId])
  @@map("crawl_screen")
}
